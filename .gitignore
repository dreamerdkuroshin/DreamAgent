# ─── DreamAgent .gitignore ───────────────────────────────────────────────────
# NEVER commit secrets, databases, or user data to version control.

# ── Secrets & Credentials ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
client_secret*.json
google_credentials*.json
service_account*.json
*_credentials.json
credentials.json
oauth_token*.json

# ── Databases ───────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
dreamagent.db
dreamagent_state.db
dreamagent_test*.db

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.pyi

# ── Virtual Environment ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
output.log
out.txt
backend_err.txt
backend_error_log.txt
test_output.txt
error_log.txt
dreamagent_run.log
full_models_list*.txt
models_list*.txt

# ── User Data & Runtime Files ────────────────────────────────────────────────
data/
tmp/
scratch/
builder_output/
*.webp
libpod/
archive/
sandbox/

# ── Test Artifacts ───────────────────────────────────────────────────────────
test_results/
test_results.json
test_res_final.txt
stress_test_report.md

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
.next/
dist/
.cache/
*.tsbuildinfo

# ── Docker / Podman ──────────────────────────────────────────────────────────
*.tar

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini