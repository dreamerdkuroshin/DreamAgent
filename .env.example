# --- DreamAgent Environment Variables ---
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control!

# ─── LLM Providers (at least 1 required) ────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CLAUDE_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
NVIDIA_API_KEY=

# ─── Search & Data Tools ─────────────────────────────────────────
TAVILY_API_KEY=
AHREFS_API_KEY=

# ─── Bot Tokens ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_TOKEN=
SLACK_BOT_TOKEN=
WHATSAPP_TOKEN=

# ─── Payments ─────────────────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Database & Storage ───────────────────────────────────────────
# SQLite (default, no setup needed):
# DATABASE_URL is not needed for SQLite — it defaults automatically.
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/dreamagent
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── OAuth Apps ───────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ─── Infrastructure ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
BACKEND_URL=http://localhost:8001
FRONTEND_DOMAIN=http://localhost:5000
BACKEND_DOMAIN=http://localhost:8001

# ─── Security ─────────────────────────────────────────────────────
# Leave blank — auto-generated on first run.
ENCRYPTION_KEY=

# ─── Feature Flags ────────────────────────────────────────────────
TOOL_PYTHON_ENABLED=true
TOOL_JS_ENABLED=true
TOOL_TERMINAL_ENABLED=true
TOOL_FILESYSTEM_ENABLED=true
TOOL_BROWSER_ENABLED=false
TOOL_TAVILY_ENABLED=true
TOOL_GOOGLE_SEARCH_ENABLED=false
TOOL_CALCULATOR_ENABLED=true
TOOL_INTELLIGENCE_ENABLED=true
MAX_STEPS=10
